  "specialRules": [
    {
      "pattern": "rri",
      "output": "ঋ",
      "priority": 1,
      "description": "Special vowel ri"
    },
    {
      "pattern": "y",
      "output": "য়",
      "priority": 2,
      "description": "Antastha ya with dot"
    },
    {
      "pattern": "Y",
      "output": "য",
      "priority": 2,
      "description": "Antastha ya without dot"
    },
    {
      "pattern": "t``",
      "output": "ৎ",
      "priority": 1,
      "description": "Khanda ta"
    },
    {
      "pattern": "....",
      "output": "...",
      "priority": 1,
      "description": "Ellipsis passthrough"
    },
    {
      "pattern": "^^",
      "output": "ঁ",
      "priority": 1,
      "description": "Chandrabindu"
    },
    {
      "pattern": ":..",
      "output": "ঃ",
      "priority": 1,
      "description": "Visarga"
    }
  ],
  "processingRules": {
    "algorithm": "longest-match-first",
    "direction": "left-to-right",
    "maxBufferLength": 10,
    "autoCommitDelay": 300,
    "disambiguation": "context-aware",
    "fallbackToEnglish": true
  }
