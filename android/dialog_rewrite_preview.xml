<?xml version="1.0" encoding="utf-8"?>
<!--
    Lorapok Keuboard — Tone Rewrite Preview Dialog
    Material Design bottom sheet layout for tone rewriting preview.
    Shows original text, rewritten text, tone selector, and action buttons.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialog_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✨ টোন পরিবর্তন করুন"
            android:textSize="20sp"
            android:textColor="#1F1F1F"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Original Text Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="মূল বার্তা:"
            android:textSize="12sp"
            android:textColor="#999999"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/text_original"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#1F1F1F"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />
    </LinearLayout>

    <!-- Tone Selector Chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingBottom="12dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_tones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp">

            <!-- Free Tones -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_formal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎩 আনুষ্ঠানিক"
                android:checkable="true"
                app:chipBackgroundColor="#E8F0FE" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_friendly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😊 বন্ধুত্বপূর্ণ"
                android:checkable="true"
                app:chipBackgroundColor="#E6F4EA" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_respectful"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🙏 শ্রদ্ধাশীল"
                android:checkable="true"
                app:chipBackgroundColor="#FEF7E0" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_concise"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ সংক্ষিপ্ত"
                android:checkable="true"
                app:chipBackgroundColor="#FCE8E6" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_detailed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 বিস্তারিত"
                android:checkable="true"
                app:chipBackgroundColor="#E8EAF6" />

            <!-- Premium Tones -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_poetic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 কাব্যিক ⭐"
                android:checkable="true"
                android:enabled="false"
                app:chipBackgroundColor="#F3E5F5" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_humorous"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="😄 হাস্যরসাত্মক ⭐"
                android:checkable="true"
                android:enabled="false"
                app:chipBackgroundColor="#FFF3E0" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_empathetic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💝 সহানুভূতিশীল ⭐"
                android:checkable="true"
                android:enabled="false"
                app:chipBackgroundColor="#FCE4EC" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Rewritten Text Preview -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#F8F9FA"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/label_rewritten"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="পরিবর্তিত বার্তা:"
                android:textSize="12sp"
                android:textColor="#1A73E8"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/text_rewritten"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#1F1F1F"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="☝️ উপরে একটি টোন নির্বাচন করুন" />

            <TextView
                android:id="@+id/text_processing_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#999999"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="4dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="বাতিল"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#666666" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_try_another"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="অন্য টোন"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginStart="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_use_this"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ব্যবহার করুন"
            android:backgroundTint="#1A73E8"
            android:textColor="@android:color/white"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
